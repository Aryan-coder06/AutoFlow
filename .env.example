# ------------------------------
# Google / Gemini
# ------------------------------
GOOGLE_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
ENABLE_IMAGE_GENERATION=true

# Optional run id override
PIPELINE_RUN_ID=

# Runtime controls
DEFAULT_SCRAPE_TOPICS=3
DEFAULT_POST_LIMIT=1
SCRAPER_MAX_LINKS_PER_TOPIC=3
SCRAPER_HEADLESS=false
DUPLICATE_BUFFER_SIZE=300
DUPLICATE_TITLE_SIMILARITY=0.72
PENDING_PUBLISH_SCAN_LIMIT=200
# Optional manual dedupe titles if wording changed across runs
# Use separator: ||
DEDUPE_EXTRA_POSTED_TITLES=
# Optional keyword dedupe for title variants; separator: ||
DEDUPE_EXTRA_POSTED_KEYWORDS=

# ------------------------------
# MongoDB
# ------------------------------

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=autoflow

# ------------------------------
# Cloudinary (for next step)
# ------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
ENABLE_CLOUDINARY_UPLOAD=true
CLOUDINARY_FOLDER=autoflow/generated

# ------------------------------
# Instagram / Meta Graph API
# ------------------------------
ENABLE_INSTAGRAM_PUBLISH=true
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_IG_USER_ID=
INSTAGRAM_PAGE_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_GRAPH_API_VERSION=v25.0

# Optional webhooks / callback
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
